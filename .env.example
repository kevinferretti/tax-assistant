# Copy to .env (gitignored) and fill in. Required for the OpenAI-backed agent.
OPENAI_API_KEY=sk-...

# Optional model overrides. If unset, the app verifies your account at startup
# and picks the best available (GPT-5 family). Chat tier is fast; vision is capable.
# OPENAI_MODEL=gpt-5.4
# OPENAI_VISION_MODEL=gpt-5.4
